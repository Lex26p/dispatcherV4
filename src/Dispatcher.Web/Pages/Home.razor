@page "/"
@inject DispatcherApiClient ApiClient

<PageTitle>Диспетчер</PageTitle>

<h1>Диспетчер</h1>

<p class="lead">
    Web-система мониторинга оборудования, текущих значений, аварий и уведомлений.
</p>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h5">API</h2>
                <p class="mb-1">@apiStatusText</p>
                <small class="text-muted">Base URL: @ApiClient.ApiBaseAddress</small>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h5">Realtime</h2>
                <p class="mb-1">@realtimeStatusText</p>
                <small class="text-muted">@realtimeHubPath</small>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h5">База данных</h2>
                <p class="mb-1">PostgreSQL пока не подключен локально.</p>
                <small class="text-muted">Data endpoints заработают после применения миграции.</small>
            </div>
        </div>
    </div>
</div>

<div class="alert alert-info">
    Следующий этап после UI-основы — подключение realtime-клиента и страницы текущих значений.
</div>

@code {
    private string apiStatusText = "Проверка API...";
    private string realtimeStatusText = "Проверка realtime...";
    private string realtimeHubPath = "Hub path пока неизвестен.";

    protected override async Task OnInitializedAsync()
    {
        await LoadStatusAsync();
    }

    private async Task LoadStatusAsync()
    {
        try
        {
            var health = await ApiClient.GetHealthAsync();
            apiStatusText = health is null
                ? "API ответил пустым результатом."
                : $"{health.Product}: {health.Status}, service: {health.Service}.";

            var realtime = await ApiClient.GetRealtimeInfoAsync();
            realtimeStatusText = realtime is null
                ? "Realtime endpoint ответил пустым результатом."
                : "SignalR endpoint доступен.";

            realtimeHubPath = string.IsNullOrWhiteSpace(realtime?.TagValuesHub)
                ? "Hub path пока неизвестен."
                : realtime.TagValuesHub;
        }
        catch (Exception ex)
        {
            apiStatusText = "API недоступен. Запусти Dispatcher.Api на http://localhost:5076.";
            realtimeStatusText = "Realtime недоступен.";
            realtimeHubPath = ex.Message;
        }
    }
}
