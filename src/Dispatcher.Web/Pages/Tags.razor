@page "/tags"
@inject DispatcherApiClient ApiClient

<PageTitle>Теги</PageTitle>

<div class="d-flex align-items-center justify-content-between gap-3 mb-4">
    <div>
        <h1 class="mb-1">Теги</h1>
        <p class="text-muted mb-0">Создание и просмотр тегов выбранного устройства.</p>
    </div>

    <button class="btn btn-outline-primary" @onclick="LoadAllAsync" disabled="@(isLoadingDevices || isLoadingTags)">
        Обновить
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-warning">
        <strong>Не удалось выполнить запрос.</strong>
        <div>@errorMessage</div>
        <div class="small mt-2">
            Если PostgreSQL пока не готов, это ожидаемо для data-запросов. Сборка и запуск UI при этом остаются корректными.
        </div>
    </div>
}

<div class="card shadow-sm mb-4">
    <div class="card-header">
        <strong>Выбор устройства</strong>
    </div>
    <div class="card-body">
        @if (isLoadingDevices)
        {
            <p class="text-muted mb-0">Загрузка устройств…</p>
        }
        else if (devices.Count == 0)
        {
            <div class="alert alert-secondary mb-0">
                Устройств пока нет или data API недоступен без PostgreSQL. Создать устройства можно на странице «Устройства».
            </div>
        }
        else
        {
            <div class="row g-3 align-items-end">
                <div class="col-12 col-lg-8">
                    <label class="form-label">Устройство</label>
                    <select class="form-select" @bind="selectedDeviceIdText" @bind:after="OnSelectedDeviceChangedAsync">
                        @foreach (var device in devices)
                        {
                            <option value="@device.Id.ToString()">
                                @device.Name — @FormatProtocol(device.Protocol) — @device.Host:@device.Port
                            </option>
                        }
                    </select>
                </div>
                <div class="col-12 col-lg-4">
                    <button class="btn btn-outline-secondary w-100" @onclick="LoadTagsAsync" disabled="@(!SelectedDeviceId.HasValue || isLoadingTags)">
                        Обновить теги
                    </button>
                </div>
            </div>
        }
    </div>
</div>

<div class="row g-4">
    <div class="col-12 col-xl-7">
        <section class="card shadow-sm">
            <div class="card-header d-flex align-items-center justify-content-between">
                <strong>Теги устройства</strong>
                <span class="badge text-bg-secondary">@tags.Count</span>
            </div>

            <div class="card-body">
                @if (!SelectedDeviceId.HasValue)
                {
                    <div class="alert alert-secondary mb-0">Выбери устройство, чтобы увидеть его теги.</div>
                }
                else if (isLoadingTags)
                {
                    <p class="text-muted mb-0">Загрузка тегов…</p>
                }
                else if (tags.Count == 0)
                {
                    <div class="alert alert-secondary mb-0">
                        Для выбранного устройства теги пока не созданы.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Название</th>
                                    <th>Код</th>
                                    <th>Протокол</th>
                                    <th>Адрес</th>
                                    <th>Тип</th>
                                    <th>Опрос</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var tag in tags)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@tag.Name</div>
                                            @if (!string.IsNullOrWhiteSpace(tag.Description))
                                            {
                                                <div class="small text-muted">@tag.Description</div>
                                            }
                                        </td>
                                        <td><code>@tag.Code</code></td>
                                        <td>@FormatProtocol(tag.Protocol)</td>
                                        <td>@FormatTagAddress(tag)</td>
                                        <td>@FormatDataType(tag.DataType)</td>
                                        <td>@tag.PollIntervalMs мс</td>
                                        <td class="text-end">
                                            <span class="@(tag.IsEnabled ? "badge text-bg-success" : "badge text-bg-secondary") me-2">
                                                @(tag.IsEnabled ? "Включен" : "Отключен")
                                            </span>
                                            @if (tag.IsEnabled)
                                            {
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => DisableTagAsync(tag.Id)">
                                                    Отключить
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-outline-success" @onclick="() => EnableTagAsync(tag.Id)">
                                                    Включить
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </section>
    </div>

    <div class="col-12 col-xl-5">
        <section class="card shadow-sm mb-4">
            <div class="card-header">
                <strong>Новый Modbus тег</strong>
            </div>

            <div class="card-body">
                <EditForm Model="@modbusTag" OnValidSubmit="CreateModbusTagAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <fieldset disabled="@(!CanCreateModbusTag || isSaving)">
                        <div class="mb-3">
                            <label class="form-label">Название</label>
                            <InputText class="form-control" @bind-Value="modbusTag.Name" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Код</label>
                            <InputText class="form-control" @bind-Value="modbusTag.Code" />
                            <div class="form-text">Уникальный код тега, например <code>boiler.temperature</code>.</div>
                        </div>

                        <div class="row g-3">
                            <div class="col-6">
                                <label class="form-label">Регистр</label>
                                <InputSelect class="form-select" @bind-Value="modbusTag.RegisterType">
                                    <option value="1">Coil</option>
                                    <option value="2">Discrete Input</option>
                                    <option value="3">Input Register</option>
                                    <option value="4">Holding Register</option>
                                </InputSelect>
                            </div>
                            <div class="col-6">
                                <label class="form-label">Адрес</label>
                                <InputNumber class="form-control" @bind-Value="modbusTag.Address" />
                            </div>
                            <div class="col-6">
                                <label class="form-label">Unit ID</label>
                                <InputNumber class="form-control" @bind-Value="modbusTag.UnitId" />
                            </div>
                            <div class="col-6">
                                <label class="form-label">Тип данных</label>
                                <InputSelect class="form-select" @bind-Value="modbusTag.DataType">
                                    @foreach (var type in DataTypes)
                                    {
                                        <option value="@type.Value">@type.Label</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-6">
                                <label class="form-label">Byte order</label>
                                <InputSelect class="form-select" @bind-Value="modbusTag.ByteOrder">
                                    <option value="1">BigEndian</option>
                                    <option value="2">LittleEndian</option>
                                </InputSelect>
                            </div>
                            <div class="col-6">
                                <label class="form-label">Word order</label>
                                <InputSelect class="form-select" @bind-Value="modbusTag.WordOrder">
                                    <option value="1">BigEndian</option>
                                    <option value="2">LittleEndian</option>
                                </InputSelect>
                            </div>
                            <div class="col-6">
                                <label class="form-label">Единица</label>
                                <InputText class="form-control" @bind-Value="modbusTag.Unit" />
                            </div>
                            <div class="col-6">
                                <label class="form-label">Опрос, мс</label>
                                <InputNumber class="form-control" @bind-Value="modbusTag.PollIntervalMs" />
                            </div>
                            <div class="col-6">
                                <label class="form-label">Scale</label>
                                <InputNumber class="form-control" @bind-Value="modbusTag.Scale" />
                            </div>
                            <div class="col-6">
                                <label class="form-label">Offset</label>
                                <InputNumber class="form-control" @bind-Value="modbusTag.Offset" />
                            </div>
                        </div>

                        <div class="form-check mt-3">
                            <InputCheckbox class="form-check-input" @bind-Value="modbusTag.HistoryEnabled" />
                            <label class="form-check-label">Сохранять историю</label>
                        </div>

                        <div class="mt-3 mb-3">
                            <label class="form-label">Описание</label>
                            <InputTextArea class="form-control" @bind-Value="modbusTag.Description" />
                        </div>
                    </fieldset>

                    <button class="btn btn-primary" type="submit" disabled="@(!CanCreateModbusTag || isSaving)">
                        Создать Modbus тег
                    </button>

                    @if (SelectedDevice is not null && SelectedDevice.Protocol != 1)
                    {
                        <div class="form-text text-warning mt-2">Выбранное устройство не Modbus TCP.</div>
                    }
                </EditForm>
            </div>
        </section>

        <section class="card shadow-sm">
            <div class="card-header">
                <strong>Новый SNMP тег</strong>
            </div>

            <div class="card-body">
                <EditForm Model="@snmpTag" OnValidSubmit="CreateSnmpTagAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <fieldset disabled="@(!CanCreateSnmpTag || isSaving)">
                        <div class="mb-3">
                            <label class="form-label">Название</label>
                            <InputText class="form-control" @bind-Value="snmpTag.Name" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Код</label>
                            <InputText class="form-control" @bind-Value="snmpTag.Code" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">OID</label>
                            <InputText class="form-control" @bind-Value="snmpTag.Oid" />
                            <div class="form-text">Например <code>1.3.6.1.2.1.1.5.0</code>.</div>
                        </div>

                        <div class="row g-3">
                            <div class="col-6">
                                <label class="form-label">Тип данных</label>
                                <InputSelect class="form-select" @bind-Value="snmpTag.DataType">
                                    @foreach (var type in DataTypes)
                                    {
                                        <option value="@type.Value">@type.Label</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-6">
                                <label class="form-label">Единица</label>
                                <InputText class="form-control" @bind-Value="snmpTag.Unit" />
                            </div>
                            <div class="col-6">
                                <label class="form-label">Опрос, мс</label>
                                <InputNumber class="form-control" @bind-Value="snmpTag.PollIntervalMs" />
                            </div>
                            <div class="col-6">
                                <label class="form-label">Scale</label>
                                <InputNumber class="form-control" @bind-Value="snmpTag.Scale" />
                            </div>
                            <div class="col-6">
                                <label class="form-label">Offset</label>
                                <InputNumber class="form-control" @bind-Value="snmpTag.Offset" />
                            </div>
                        </div>

                        <div class="form-check mt-3">
                            <InputCheckbox class="form-check-input" @bind-Value="snmpTag.HistoryEnabled" />
                            <label class="form-check-label">Сохранять историю</label>
                        </div>

                        <div class="mt-3 mb-3">
                            <label class="form-label">Описание</label>
                            <InputTextArea class="form-control" @bind-Value="snmpTag.Description" />
                        </div>
                    </fieldset>

                    <button class="btn btn-primary" type="submit" disabled="@(!CanCreateSnmpTag || isSaving)">
                        Создать SNMP тег
                    </button>

                    @if (SelectedDevice is not null && SelectedDevice.Protocol != 2)
                    {
                        <div class="form-text text-warning mt-2">Выбранное устройство не SNMP.</div>
                    }
                </EditForm>
            </div>
        </section>
    </div>
</div>

@code {
    private static readonly IReadOnlyList<SelectOption> DataTypes = new[]
    {
        new SelectOption(1, "Bool"),
        new SelectOption(2, "Int16"),
        new SelectOption(3, "UInt16"),
        new SelectOption(4, "Int32"),
        new SelectOption(5, "UInt32"),
        new SelectOption(6, "Float32"),
        new SelectOption(7, "Float64"),
        new SelectOption(8, "String")
    };

    private IReadOnlyList<DeviceDto> devices = Array.Empty<DeviceDto>();
    private IReadOnlyList<TagDto> tags = Array.Empty<TagDto>();

    private CreateModbusTagRequest modbusTag = new();
    private CreateSnmpTagRequest snmpTag = new();

    private string selectedDeviceIdText = string.Empty;
    private bool isLoadingDevices;
    private bool isLoadingTags;
    private bool isSaving;
    private string? errorMessage;
    private string? successMessage;

    private Guid? SelectedDeviceId => Guid.TryParse(selectedDeviceIdText, out var id) ? id : null;

    private DeviceDto? SelectedDevice => SelectedDeviceId is Guid id
        ? devices.FirstOrDefault(device => device.Id == id)
        : null;

    private bool CanCreateModbusTag => SelectedDevice is { Protocol: 1 };

    private bool CanCreateSnmpTag => SelectedDevice is { Protocol: 2 };

    protected override async Task OnInitializedAsync()
    {
        await LoadAllAsync();
    }

    private async Task LoadAllAsync()
    {
        isLoadingDevices = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            devices = await ApiClient.GetDevicesAsync();
            EnsureSelectedDevice();
            await LoadTagsAsync();
        }
        catch (Exception exception)
        {
            devices = Array.Empty<DeviceDto>();
            tags = Array.Empty<TagDto>();
            selectedDeviceIdText = string.Empty;
            errorMessage = exception.Message;
        }
        finally
        {
            isLoadingDevices = false;
        }
    }

    private async Task OnSelectedDeviceChangedAsync()
    {
        errorMessage = null;
        successMessage = null;
        await LoadTagsAsync();
    }

    private async Task LoadTagsAsync()
    {
        if (SelectedDeviceId is not Guid deviceId)
        {
            tags = Array.Empty<TagDto>();
            return;
        }

        isLoadingTags = true;

        try
        {
            tags = await ApiClient.GetDeviceTagsAsync(deviceId);
        }
        catch (Exception exception)
        {
            tags = Array.Empty<TagDto>();
            errorMessage = exception.Message;
        }
        finally
        {
            isLoadingTags = false;
        }
    }

    private async Task CreateModbusTagAsync()
    {
        await SaveAsync(async deviceId =>
        {
            modbusTag.DeviceId = deviceId;
            var created = await ApiClient.CreateModbusTagAsync(modbusTag);
            modbusTag = new CreateModbusTagRequest { DeviceId = deviceId };
            successMessage = $"Modbus тег «{created.Name}» создан.";
        });
    }

    private async Task CreateSnmpTagAsync()
    {
        await SaveAsync(async deviceId =>
        {
            snmpTag.DeviceId = deviceId;
            var created = await ApiClient.CreateSnmpTagAsync(snmpTag);
            snmpTag = new CreateSnmpTagRequest { DeviceId = deviceId };
            successMessage = $"SNMP тег «{created.Name}» создан.";
        });
    }

    private async Task EnableTagAsync(Guid id)
    {
        await SaveAsync(async _ =>
        {
            await ApiClient.EnableTagAsync(id);
            successMessage = "Тег включен.";
        });
    }

    private async Task DisableTagAsync(Guid id)
    {
        await SaveAsync(async _ =>
        {
            await ApiClient.DisableTagAsync(id);
            successMessage = "Тег отключен.";
        });
    }

    private async Task SaveAsync(Func<Guid, Task> operation)
    {
        if (SelectedDeviceId is not Guid deviceId)
        {
            errorMessage = "Сначала выбери устройство.";
            return;
        }

        isSaving = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            await operation(deviceId);
            await LoadTagsAsync();
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private void EnsureSelectedDevice()
    {
        if (SelectedDeviceId is Guid selectedId && devices.Any(device => device.Id == selectedId))
        {
            return;
        }

        selectedDeviceIdText = devices.FirstOrDefault()?.Id.ToString() ?? string.Empty;
    }

    private static string FormatProtocol(int protocol)
    {
        return protocol switch
        {
            1 => "Modbus TCP",
            2 => "SNMP",
            _ => $"Unknown ({protocol})"
        };
    }

    private static string FormatDataType(int dataType)
    {
        return dataType switch
        {
            1 => "Bool",
            2 => "Int16",
            3 => "UInt16",
            4 => "Int32",
            5 => "UInt32",
            6 => "Float32",
            7 => "Float64",
            8 => "String",
            _ => $"Unknown ({dataType})"
        };
    }

    private static string FormatRegisterType(int registerType)
    {
        return registerType switch
        {
            1 => "Coil",
            2 => "Discrete Input",
            3 => "Input Register",
            4 => "Holding Register",
            _ => $"Unknown ({registerType})"
        };
    }

    private static string FormatTagAddress(TagDto tag)
    {
        if (tag.Protocol == 1)
        {
            return $"{FormatRegisterType(tag.ModbusRegisterType ?? 0)} {tag.ModbusAddress ?? 0}, Unit {tag.ModbusUnitId ?? 0}";
        }

        if (tag.Protocol == 2)
        {
            return tag.SnmpOid ?? "OID не задан";
        }

        return "—";
    }

    private sealed record SelectOption(int Value, string Label);
}
