@page "/devices"
@inject DispatcherApiClient ApiClient

<PageTitle>Устройства</PageTitle>

<div class="d-flex align-items-center justify-content-between gap-3 mb-4">
    <div>
        <h1 class="mb-1">Устройства</h1>
        <p class="text-muted mb-0">Создание и просмотр устройств Modbus TCP и SNMP.</p>
    </div>

    <button class="btn btn-outline-primary" @onclick="LoadDevicesAsync" disabled="@isLoading">
        Обновить
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-warning">
        <strong>Не удалось выполнить запрос.</strong>
        <div>@errorMessage</div>
        <div class="small mt-2">
            Если PostgreSQL пока не готов, это ожидаемо для data-запросов. Сборка и запуск UI при этом остаются корректными.
        </div>
    </div>
}

<div class="row g-4">
    <div class="col-12 col-xl-7">
        <section class="card shadow-sm">
            <div class="card-header d-flex align-items-center justify-content-between">
                <strong>Список устройств</strong>
                <span class="badge text-bg-secondary">@devices.Count</span>
            </div>

            <div class="card-body">
                @if (isLoading)
                {
                    <p class="text-muted mb-0">Загрузка устройств…</p>
                }
                else if (devices.Count == 0)
                {
                    <div class="alert alert-secondary mb-0">
                        Устройств пока нет или data API недоступен без PostgreSQL.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Название</th>
                                    <th>Протокол</th>
                                    <th>Адрес</th>
                                    <th>Статус</th>
                                    <th>Опрос</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var device in devices)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@device.Name</div>
                                            @if (!string.IsNullOrWhiteSpace(device.Description))
                                            {
                                                <div class="small text-muted">@device.Description</div>
                                            }
                                        </td>
                                        <td>@FormatProtocol(device.Protocol)</td>
                                        <td><code>@device.Host:@device.Port</code></td>
                                        <td>
                                            <span class="@GetStatusBadgeClass(device.Status, device.IsEnabled)">
                                                @FormatStatus(device.Status, device.IsEnabled)
                                            </span>
                                        </td>
                                        <td>@device.PollIntervalMs мс</td>
                                        <td class="text-end">
                                            @if (device.IsEnabled)
                                            {
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => DisableDeviceAsync(device.Id)">
                                                    Отключить
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-outline-success" @onclick="() => EnableDeviceAsync(device.Id)">
                                                    Включить
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </section>
    </div>

    <div class="col-12 col-xl-5">
        <section class="card shadow-sm mb-4">
            <div class="card-header">
                <strong>Новое Modbus TCP устройство</strong>
            </div>

            <div class="card-body">
                <EditForm Model="@modbusDevice" OnValidSubmit="CreateModbusDeviceAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-3">
                        <label class="form-label">Название</label>
                        <InputText class="form-control" @bind-Value="modbusDevice.Name" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Host</label>
                        <InputText class="form-control" @bind-Value="modbusDevice.Host" />
                    </div>

                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label">Порт</label>
                            <InputNumber class="form-control" @bind-Value="modbusDevice.Port" />
                        </div>
                        <div class="col-6">
                            <label class="form-label">Опрос, мс</label>
                            <InputNumber class="form-control" @bind-Value="modbusDevice.PollIntervalMs" />
                        </div>
                        <div class="col-6">
                            <label class="form-label">Timeout, мс</label>
                            <InputNumber class="form-control" @bind-Value="modbusDevice.TimeoutMs" />
                        </div>
                        <div class="col-6">
                            <label class="form-label">Повторы</label>
                            <InputNumber class="form-control" @bind-Value="modbusDevice.RetryCount" />
                        </div>
                    </div>

                    <div class="mt-3 mb-3">
                        <label class="form-label">Описание</label>
                        <InputTextArea class="form-control" @bind-Value="modbusDevice.Description" />
                    </div>

                    <button class="btn btn-primary" type="submit" disabled="@isSaving">
                        Создать Modbus TCP
                    </button>
                </EditForm>
            </div>
        </section>

        <section class="card shadow-sm">
            <div class="card-header">
                <strong>Новое SNMP устройство</strong>
            </div>

            <div class="card-body">
                <EditForm Model="@snmpDevice" OnValidSubmit="CreateSnmpDeviceAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-3">
                        <label class="form-label">Название</label>
                        <InputText class="form-control" @bind-Value="snmpDevice.Name" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Host</label>
                        <InputText class="form-control" @bind-Value="snmpDevice.Host" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Community</label>
                        <InputText class="form-control" @bind-Value="snmpDevice.Community" />
                    </div>

                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label">Версия</label>
                            <InputNumber class="form-control" @bind-Value="snmpDevice.Version" />
                            <div class="form-text">1 = v1, 2 = v2c, 3 = v3</div>
                        </div>
                        <div class="col-6">
                            <label class="form-label">Порт</label>
                            <InputNumber class="form-control" @bind-Value="snmpDevice.Port" />
                        </div>
                        <div class="col-6">
                            <label class="form-label">Опрос, мс</label>
                            <InputNumber class="form-control" @bind-Value="snmpDevice.PollIntervalMs" />
                        </div>
                        <div class="col-6">
                            <label class="form-label">Timeout, мс</label>
                            <InputNumber class="form-control" @bind-Value="snmpDevice.TimeoutMs" />
                        </div>
                    </div>

                    <div class="mt-3 mb-3">
                        <label class="form-label">Описание</label>
                        <InputTextArea class="form-control" @bind-Value="snmpDevice.Description" />
                    </div>

                    <button class="btn btn-primary" type="submit" disabled="@isSaving">
                        Создать SNMP
                    </button>
                </EditForm>
            </div>
        </section>
    </div>
</div>

@code {
    private IReadOnlyList<DeviceDto> devices = Array.Empty<DeviceDto>();
    private CreateModbusDeviceRequest modbusDevice = new();
    private CreateSnmpDeviceRequest snmpDevice = new();

    private bool isLoading;
    private bool isSaving;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadDevicesAsync();
    }

    private async Task LoadDevicesAsync()
    {
        isLoading = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            devices = await ApiClient.GetDevicesAsync();
        }
        catch (Exception exception)
        {
            devices = Array.Empty<DeviceDto>();
            errorMessage = exception.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CreateModbusDeviceAsync()
    {
        await SaveAsync(async () =>
        {
            var created = await ApiClient.CreateModbusDeviceAsync(modbusDevice);
            modbusDevice = new CreateModbusDeviceRequest();
            successMessage = $"Устройство «{created.Name}» создано.";
        });
    }

    private async Task CreateSnmpDeviceAsync()
    {
        await SaveAsync(async () =>
        {
            var created = await ApiClient.CreateSnmpDeviceAsync(snmpDevice);
            snmpDevice = new CreateSnmpDeviceRequest();
            successMessage = $"Устройство «{created.Name}» создано.";
        });
    }

    private async Task EnableDeviceAsync(Guid id)
    {
        await SaveAsync(async () =>
        {
            await ApiClient.EnableDeviceAsync(id);
            successMessage = "Устройство включено.";
        });
    }

    private async Task DisableDeviceAsync(Guid id)
    {
        await SaveAsync(async () =>
        {
            await ApiClient.DisableDeviceAsync(id);
            successMessage = "Устройство отключено.";
        });
    }

    private async Task SaveAsync(Func<Task> operation)
    {
        isSaving = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            await operation();
            await LoadDevicesAsync();
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private static string FormatProtocol(int protocol)
    {
        return protocol switch
        {
            1 => "Modbus TCP",
            2 => "SNMP",
            _ => $"Unknown ({protocol})"
        };
    }

    private static string FormatStatus(int status, bool isEnabled)
    {
        if (!isEnabled)
        {
            return "Отключено";
        }

        return status switch
        {
            0 => "Неизвестно",
            1 => "Онлайн",
            2 => "Офлайн",
            3 => "Отключено",
            4 => "Ошибка",
            _ => $"Unknown ({status})"
        };
    }

    private static string GetStatusBadgeClass(int status, bool isEnabled)
    {
        if (!isEnabled)
        {
            return "badge text-bg-secondary";
        }

        return status switch
        {
            1 => "badge text-bg-success",
            2 => "badge text-bg-warning",
            4 => "badge text-bg-danger",
            _ => "badge text-bg-light"
        };
    }
}
